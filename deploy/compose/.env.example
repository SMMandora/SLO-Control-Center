# Chaos knobs for orders-api. Copy to .env and adjust, then `docker compose up`.
# Fraction of requests forced to 5xx (0..1).
CHAOS_ERROR_RATE=0
# Injected latency in milliseconds, applied to CHAOS_LATENCY_PCT of requests.
CHAOS_LATENCY_MS=0
# Fraction of requests that receive the injected latency (0..1).
CHAOS_LATENCY_PCT=0
